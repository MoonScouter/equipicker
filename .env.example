# Copy this file to .env and fill in the current remote MySQL details.
#
# Option A: one full SQLAlchemy URL.
# EQUIPICKER_DATABASE_URL=mysql+mysqlconnector://user:password@host:3306/database?charset=utf8mb4
#
# Option B: separate fields.
EQUIPICKER_DB_HOST=
EQUIPICKER_DB_PORT=3306
EQUIPICKER_DB_NAME=
EQUIPICKER_DB_USER=
EQUIPICKER_DB_PASSWORD=
EQUIPICKER_DB_CHARSET=utf8mb4
