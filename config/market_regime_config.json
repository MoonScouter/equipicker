        "defensive": {"Bull": 60, "Emerging Bull": 55, "Neutral": 50, "Emerging Bear": 20, "Bear": 10},
        "rate_sensitive": {"Bull": 55, "Emerging Bull": 50, "Neutral": 50, "Emerging Bear": 20, "Bear": 10}
      },
      "sector_overrides": {}
    },
    "Recovery": {
