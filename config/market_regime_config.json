        "offensive": {"Bull": 90, "Emerging Bull": 80, "Neutral": 55, "Emerging Bear": 20, "Bear": 10},
        "cyclical": {"Bull": 100, "Emerging Bull": 85, "Neutral": 55, "Emerging Bear": 15, "Bear": 5},
        "defensive": {"Bull": 50, "Emerging Bull": 45, "Neutral": 50, "Emerging Bear": 25, "Bear": 15},
        "rate_sensitive": {"Bull": 70, "Emerging Bull": 60, "Neutral": 50, "Emerging Bear": 25, "Bear": 15}
      },
      "sector_overrides": {}
    },
    "Neutral / Transition": {
      "family_defaults": {
        "offensive": {"Bull": 65, "Emerging Bull": 60, "Neutral": 50, "Emerging Bear": 35, "Bear": 20},
        "cyclical": {"Bull": 65, "Emerging Bull": 60, "Neutral": 50, "Emerging Bear": 35, "Bear": 20},
        "defensive": {"Bull": 65, "Emerging Bull": 60, "Neutral": 50, "Emerging Bear": 35, "Bear": 20},
        "rate_sensitive": {"Bull": 55, "Emerging Bull": 55, "Neutral": 50, "Emerging Bear": 35, "Bear": 20}
      },
      "sector_overrides": {}
    },
    "Late Cycle / Defensive": {
      "family_defaults": {
        "offensive": {"Bull": 35, "Emerging Bull": 30, "Neutral": 40, "Emerging Bear": 20, "Bear": 10},
        "cyclical": {"Bull": 55, "Emerging Bull": 45, "Neutral": 45, "Emerging Bear": 25, "Bear": 10},
        "defensive": {"Bull": 100, "Emerging Bull": 80, "Neutral": 55, "Emerging Bear": 25, "Bear": 10},
        "rate_sensitive": {"Bull": 50, "Emerging Bull": 45, "Neutral": 45, "Emerging Bear": 25, "Bear": 10}
