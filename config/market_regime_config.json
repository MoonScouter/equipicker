        "cyclical": {"Bull": 20, "Emerging Bull": 15, "Neutral": 35, "Emerging Bear": 10, "Bear": 5},
        "defensive": {"Bull": 95, "Emerging Bull": 75, "Neutral": 55, "Emerging Bear": 20, "Bear": 10},
